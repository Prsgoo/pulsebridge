{
  "name": "pulsebridge",
  "version": "0.1.0-alpha.9",
  "description": "Plugin-based integration runtime for connecting external systems, normalizing data into canonical records, and processing them through composable processor plugins.",
  "license": "MIT",
  "keywords": [
    "integration",
    "plugin",
    "runtime",
    "data-pipeline",
    "canonical-records",
    "processor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Prsgoo/pulsebridge.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "docs": "typedoc",
    "prepare": "husky",
    "publish:local": "npm publish --registry http://localhost:4873",
    "publish:local:alpha": "npm publish --registry http://localhost:4873 --tag alpha",
    "publish:npm": "npm publish --access public"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "ioredis": "^5.6.0",
    "ioredis-mock": "^8.9.0",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "ioredis": "^5.6.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
